# =================================================================
# METIN2 WEB-PANEL CONFIGURATION EXAMPLE
# Copy this to .env and fill in your details.
# =================================================================

# Server Port (Frontend/Backend)
PORT=3000
APP_URL=http://localhost:3000

# Database Connection (MySQL / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

# Security
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES=7d

# Setup Status (Change to true after initial setup)
SETUP_DONE=false
